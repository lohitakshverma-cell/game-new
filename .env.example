# --- Vercel KV (Upstash Redis) : provision from the Vercel dashboard -> Storage ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Access control ---
# Only e-mails on this domain can play. Defaults to beminimalist.co if unset.
# Set to "any" (or "*") to allow ANY email address.
ALLOWED_EMAIL_DOMAIN=beminimalist.co

# --- Secrets (set to long random strings) ---
# Signs the session cookie that identifies a player.
SESSION_SECRET=change-me-to-a-long-random-string
# Password for the private /admin winner dashboard.
ADMIN_SECRET=change-me-too
