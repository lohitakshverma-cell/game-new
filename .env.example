# --- Vercel KV (Upstash Redis) : provision from the Vercel dashboard -> Storage ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Resend (free tier) : https://resend.com ---
RESEND_API_KEY=
# The verified "from" address on your Resend account (e.g. Formula Finder <noreply@beminimalist.co>)
RESEND_FROM="Formula Finder <onboarding@resend.dev>"

# --- Access control ---
# Only e-mails on this domain can receive an OTP / play. Defaults to beminimalist.co if unset.
ALLOWED_EMAIL_DOMAIN=beminimalist.co

# --- Secrets (set to long random strings) ---
# Signs the short-lived "verified" session cookie.
SESSION_SECRET=change-me-to-a-long-random-string
# Password for the private /admin winner dashboard.
ADMIN_SECRET=change-me-too
